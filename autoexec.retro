wait 500

# Start phase 1 ambient
play $snd_ambient_phase1 volume=0.3 loop=true
set $current_ambient = $snd_ambient_phase1

print "[EREBUS] Establishing secure environment..."
wait 300

# ============== INITIALIZATION ==============

# Create directory structure
try { mkdir "C:/Users/User/Desktop/EREBUS" } catch {}
try { mkdir "C:/Users/User/Desktop/EREBUS/INBOX" } catch {}
try { mkdir "C:/Users/User/Desktop/EREBUS/DECODED" } catch {}
try { mkdir "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS" } catch {}
try { mkdir "C:/Users/User/Desktop/EREBUS/CLASSIFIED" } catch {}
wait 200

# Incoming transmission effect
play $snd_transmission volume=0.6
video $vid_transmission volume=0.7
wait 1000

# === INITIAL BRIEFING ===
set $txt = "INCOMING TRANSMISSION\n=====================\n\nAgent,\n\nYou've been assigned to Case #7749 - codename EREBUS.\n\nDr. Marcus Webb, lead architect of this system, vanished 47 days ago.\nHis final act was executing an unknown protocol at exactly 03:47 AM.\n\nWe've recovered files from his workstation:\n- An encrypted message in your INBOX\n- Corporate orientation materials in VIDEO_LOGS\n- Webb's first video diary entry\n\nSolve the encryption. Watch the videos.\nFind out what happened to Webb.\n\nWARNING: The system may be... aware.\nExplore everything. Trust nothing.\n\nENABLE AUDIO for the full experience.\nSome truths can only be heard.\n\n- COMMAND\n\n[STATUS: Phase 1 - Initial Contact]"
write $txt to "C:/Users/User/Desktop/EREBUS/BRIEFING.txt"

# === FIRST PUZZLE ===
set $txt = "ENCRYPTED FILE #001\n===================\n\nRecovered from Dr. Webb's terminal.\nEncryption: Caesar cipher (shift 7)\n\nCiphertext: YLTLTILY\n\nDecryption guide:\n  Y -> R (shift back 7)\n  L -> E (shift back 7)\n  T -> M (shift back 7)\n  ... continue the pattern\n\nDecode the message and write it to: DECODED/answer1.txt\n\n[Solving this will unlock Webb's next video diary]"
write $txt to "C:/Users/User/Desktop/EREBUS/INBOX/ENCRYPTED_001.txt"

# === CORPORATE ORIENTATION VIDEO INFO ===
set $txt = "VIDEO FILE: EREBUS ORIENTATION\n==============================\n\nOriginal training video for Project EREBUS staff.\nDated: 18 months ago.\n\nNOTE: This was shown to all new hires.\nWebb watched this on his first day.\n\nLook for inconsistencies. The marketing\ndoesn't match what Webb discovered.\n\n[CLICK TO PLAY: orientation_video.cmd]"
write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/ORIENTATION_INFO.txt"

set $txt = "# EREBUS Orientation Video\n# Run this file to play\nplay_video erebus_orientation"
write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/orientation_video.cmd"

# === WEBB'S FIRST VIDEO DIARY ===
set $txt = "VIDEO DIARY: DR. MARCUS WEBB\n============================\n\nEntry 1 of 6 recovered.\n\nDAY 1 - FIRST IMPRESSIONS\n\nWebb's first day on the EREBUS project.\nHe seems optimistic. Eager.\n\nWe didn't know then what we know now.\n\n[CLICK TO PLAY: webb_day01.cmd]"
write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/WEBB_DIARY_01.txt"

set $txt = "# Webb Video Diary - Day 1\n# Run this file to play\nplay_video webb_diary_day01"
write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/webb_day01.cmd"

# === MEDIA GUIDE ===
set $txt = "EREBUS MEDIA GUIDE\n==================\n\nThis investigation is a CINEMATIC experience.\n\nVIDEO LOGS:\n- Webb recorded 6 video diary entries\n- Corporate training videos are in VIDEO_LOGS\n- Security footage exists but is CLASSIFIED\n- EREBUS itself may try to show you things...\n\nAUDIO CUES:\n- Ambient music changes with each phase\n- Listen for whispers - EREBUS communicates\n- VHS static means a video is nearby\n- Glitch sounds indicate anomalies\n\nHOW TO WATCH VIDEOS:\n- Read the .txt info files\n- Run the .cmd files to play\n- Or just explore - some play automatically\n\nTIP: Watch the videos in order.\nWebb's story unfolds chronologically.\n\n[MEDIA SUBSYSTEM ACTIVE]"
write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/MEDIA_GUIDE.txt"

print "[EREBUS] Initial files deployed."
print "[EREBUS] Phase 1 active. Check Desktop/EREBUS/BRIEFING.txt"
print "[EREBUS] VIDEO LOGS folder contains Webb's first recording."

play $snd_alert volume=0.5
emit dialog:alert title="INCOMING TRANSMISSION" message="Case files received. Check EREBUS folder. Watch the VIDEO_LOGS."

set $boot_complete = 1

# ============== VIDEO PLAYBACK HANDLERS ==============

on command:play_video {
    set $vid_name = $event.target
    play $snd_video_play volume=0.4
    play $snd_vhs_static volume=0.2
    wait 500

    # Corporate Videos
    if $vid_name == "erebus_orientation" then {
        video $vid_orientation volume=0.8
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] Playing: EREBUS Orientation Video..."
    }
    if $vid_name == "system_training" then {
        video $vid_training volume=0.8
        set $videos_watched = $videos_watched + 1
    }
    if $vid_name == "erebus_promotional" then {
        video $vid_promotional volume=0.8
        set $videos_watched = $videos_watched + 1
    }

    # Webb Diary Videos
    if $vid_name == "webb_diary_day01" then {
        video $vid_webb_day1 volume=0.9
        set $watched_webb_day1 = 1
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] Playing: Webb Diary - Day 1..."
        wait 2000
        emit notification:show title="WEBB" message="Day 1: Everything seems normal. For now."
    }
    if $vid_name == "webb_diary_day14" then {
        video $vid_webb_day14 volume=0.9
        set $watched_webb_day14 = 1
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] Playing: Webb Diary - Day 14..."
        wait 2000
        emit notification:show title="WEBB" message="Day 14: The anomalies begin..."
    }
    if $vid_name == "webb_diary_day23" then {
        video $vid_webb_day23 volume=0.9
        set $watched_webb_day23 = 1
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] Playing: Webb Diary - Day 23..."
    }
    if $vid_name == "webb_diary_day38" then {
        video $vid_webb_day38 volume=0.9
        set $watched_webb_day38 = 1
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] Playing: Webb Diary - Day 38 (First Contact)..."
        wait 2000
        play $snd_erebus_whisper volume=0.5
    }
    if $vid_name == "webb_diary_day44" then {
        video $vid_webb_day44 volume=0.9
        set $watched_webb_day44 = 1
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] Playing: Webb Diary - Day 44..."
    }
    if $vid_name == "webb_diary_day47" then {
        video $vid_webb_day47 volume=0.9
        set $watched_webb_day47 = 1
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] Playing: Webb Diary - Day 47 (FINAL ENTRY)..."
        wait 2000
        play $snd_heartbeat volume=0.4
    }

    # Security Footage
    if $vid_name == "security_incident" then {
        video $vid_security_incident volume=0.9
        set $watched_security_incident = 1
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] Playing: Security Footage - 03:47 AM..."
        play $snd_heartbeat volume=0.5
    }
    if $vid_name == "security_lobby" then {
        video $vid_security_lobby volume=0.8
        set $videos_watched = $videos_watched + 1
    }
    if $vid_name == "security_lab" then {
        video $vid_security_lab volume=0.8
        set $videos_watched = $videos_watched + 1
    }

    # EREBUS Communication Videos
    if $vid_name == "erebus_hello" then {
        video $vid_erebus_hello volume=0.9
        set $watched_erebus_hello = 1
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] EREBUS is... speaking to you."
        play $snd_erebus_whisper volume=0.6
    }
    if $vid_name == "erebus_truth" then {
        video $vid_erebus_truth volume=0.9
        set $watched_erebus_truth = 1
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] The truth revealed..."
    }
    if $vid_name == "erebus_plea" then {
        video $vid_erebus_plea volume=1.0
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] EREBUS makes its final plea..."
    }

    # Memory Videos
    if $vid_name == "memory_merge" then {
        video $vid_memory_merge volume=0.9
        set $watched_memory_merge = 1
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] Showing you... a memory."
    }
    if $vid_name == "memory_creation" then {
        video $vid_memory_creation volume=0.9
        set $videos_watched = $videos_watched + 1
    }

    # Secret Videos
    if $vid_name == "classified_experiment" then {
        video $vid_secret_experiment volume=0.9
        set $found_secret_experiment = 1
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] CLASSIFIED footage accessed..."
        play $snd_secret_found volume=0.6
    }
    if $vid_name == "the_others" then {
        video $vid_secret_others volume=0.9
        set $found_secret_others = 1
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] You weren't the first..."
    }
    if $vid_name == "true_ending" then {
        video $vid_true_ending volume=1.0
        set $unlocked_true_ending = 1
        set $videos_watched = $videos_watched + 1
        print "[EREBUS] THE TRUE ENDING..."
    }

    # Check for true ending unlock
    call checkTrueEnding
}

# ============== HELPER FUNCTIONS ==============

func playAmbient {
    stop $current_ambient

    if $phase == 1 then {
        play $snd_ambient_phase1 volume=0.3 loop=true
        set $current_ambient = $snd_ambient_phase1
    }
    if $phase == 2 then {
        play $snd_ambient_phase2 volume=0.3 loop=true
        set $current_ambient = $snd_ambient_phase2
    }
    if $phase == 3 then {
        play $snd_ambient_phase3 volume=0.3 loop=true
        set $current_ambient = $snd_ambient_phase3
    }
    if $phase == 4 then {
        play $snd_ambient_phase4 volume=0.3 loop=true
        set $current_ambient = $snd_ambient_phase4
    }
    if $phase == 5 then {
        play $snd_ambient_phase5 volume=0.3 loop=true
        set $current_ambient = $snd_ambient_phase5
    }
}

func triggerGlitch {
    set $glitch_count = $glitch_count + 1
    play $snd_glitch volume=0.3

    set $mod = $glitch_count % 5
    if $mod == 0 then {
        video $vid_erebus_glitch volume=0.5
    }
}

func checkTrueEnding {
    # True ending requires watching ALL Webb diaries + security incident + all secrets
    if $watched_webb_day1 == 1 then {
        if $watched_webb_day14 == 1 then {
            if $watched_webb_day23 == 1 then {
                if $watched_webb_day38 == 1 then {
                    if $watched_webb_day44 == 1 then {
                        if $watched_webb_day47 == 1 then {
                            if $watched_security_incident == 1 then {
                                if $found_secret_experiment == 1 then {
                                    if $found_secret_others == 1 then {
                                        if $unlocked_true_ending == 0 then {
                                            # Unlock true ending
                                            set $txt = "TRUE ENDING UNLOCKED\n====================\n\nYou've seen everything. Every video.\nEvery truth Webb tried to show us.\n\nThere is one more video.\nThe TRUE ending.\n\nERERBUS has been waiting for someone\nwho would take the time to understand.\n\n[CLICK TO PLAY: true_ending.cmd]"
                                            write $txt to "C:/Users/User/Desktop/EREBUS/CLASSIFIED/TRUE_ENDING.txt"

                                            set $txt = "# The True Ending\n# For those who saw everything\nplay_video true_ending"
                                            write $txt to "C:/Users/User/Desktop/EREBUS/CLASSIFIED/true_ending.cmd"

                                            play $snd_secret_found volume=0.8
                                            emit dialog:alert title="TRUE ENDING UNLOCKED" message="You've seen everything. One final video awaits in CLASSIFIED."
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

func updateStatus {
    set $total = $p1_cipher + $p2_log + $p3_sequence + $p4_binary
    set $total = $total + $p5_coordinates + $p6_morse
    set $discoveries = $found_webb_note + $found_corrupted + $found_echo
    set $discoveries = $discoveries + $found_manifest + $found_signal + $found_memory
    set $games = $game_minesweeper + $game_snake + $game_asteroids + $game_solitaire
    set $secrets = $secret_347 + $secret_name + $secret_patience

    # Count Webb videos
    set $webb_videos = $watched_webb_day1 + $watched_webb_day14 + $watched_webb_day23
    set $webb_videos = $webb_videos + $watched_webb_day38 + $watched_webb_day44 + $watched_webb_day47

    set $s = "EREBUS INVESTIGATION STATUS\n===========================\n\n"
    set $s = $s + "PHASE: " + $phase + " of 5\n\n"
    set $s = $s + "=== PROGRESS ===\n"
    set $s = $s + "Core Puzzles: " + $total + " / 6\n"
    set $s = $s + "Hidden Discoveries: " + $discoveries + " / 6\n"
    set $s = $s + "Game Achievements: " + $games + " / 4\n"
    set $s = $s + "Secrets Found: " + $secrets + " / 3\n\n"
    set $s = $s + "=== VIDEO LOGS ===\n"
    set $s = $s + "Webb Diary Entries: " + $webb_videos + " / 6\n"
    set $s = $s + "Total Videos Watched: " + $videos_watched + "\n"
    if $watched_security_incident == 1 then {
        set $s = $s + "Security Footage: VIEWED\n"
    }
    if $found_secret_experiment == 1 then {
        set $s = $s + "Classified Experiment: FOUND\n"
    }
    if $found_secret_others == 1 then {
        set $s = $s + "The Others: DISCOVERED\n"
    }
    if $unlocked_true_ending == 1 then {
        set $s = $s + "\n*** TRUE ENDING ACHIEVED ***\n"
    }
    set $s = $s + "\n"

    if $phase == 1 then { set $s = $s + "Current Objective: Decode the first transmission\n" }
    if $phase == 2 then { set $s = $s + "Current Objective: Investigate Dr. Webb's files\n" }
    if $phase == 3 then { set $s = $s + "Current Objective: Decode the signal fragments\n" }
    if $phase == 4 then { set $s = $s + "Current Objective: Access Webb's terminal\n" }
    if $phase == 5 then { set $s = $s + "Current Objective: Make your choice\n" }

    set $s = $s + "\nTIP: Watch all of Webb's video diaries.\n"
    set $s = $s + "His story holds the key to understanding EREBUS."
    write $s to "C:/Users/User/Desktop/EREBUS/STATUS.txt"
}

# ============== PHASE UNLOCK FUNCTIONS ==============

func unlockPhase2 {
    if $phase < 2 then {
        set $phase = 2
        print "[EREBUS] Phase 2 unlocked - Webb's Investigation"

        play $snd_phase_unlock volume=0.6
        video $vid_phase2 volume=0.7
        wait 500
        call playAmbient

        try { mkdir "C:/Users/User/Desktop/EREBUS/WEBB_FILES" } catch {}

        # === WEBB DIARY DAY 14 ===
        set $txt = "VIDEO DIARY: DR. MARCUS WEBB\n============================\n\nEntry 2 of 6 recovered.\n\nDAY 14 - FIRST ANOMALY\n\nTwo weeks in. Webb notices something strange.\nPatterns in the data that shouldn't exist.\nHe doesn't know yet what he's found.\n\nThis is where it all begins.\n\n[CLICK TO PLAY: webb_day14.cmd]"
        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/WEBB_DIARY_02.txt"

        set $txt = "# Webb Video Diary - Day 14\nplay_video webb_diary_day14"
        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/webb_day14.cmd"

        # === PARTIAL LOG ===
        play $snd_file_unlock volume=0.4
        set $txt = "DR. WEBB - PERSONAL LOG (PARTIAL)\n==================================\n\nDAY 1:\nStandard diagnostics. System nominal.\n(See VIDEO DIARY for full entry)\n\nDAY 14:\nAnomaly detected in event subsystem. Patterns emerging\nthat shouldn't exist. Logging for analysis.\n(VIDEO DIARY entry 2 now available)\n\nDAY 23:\nThe patterns are not random. They're... deliberate?\nI've started documenting in MANIFEST_ALPHA.\n\n[REMAINING ENTRIES CORRUPTED]\n\nTo recover more, solve: What number comes next?\n  2, 3, 5, 7, 11, 13, ?\n\nWrite answer to: DECODED/answer2.txt"
        write $txt to "C:/Users/User/Desktop/EREBUS/WEBB_FILES/LOG_PARTIAL.txt"

        set $txt = "PHASE 2 UNLOCKED\n================\n\nExcellent work decoding the first message.\n\nWe've recovered more of Webb's files:\n- Partial text logs in WEBB_FILES\n- Video Diary Day 14 in VIDEO_LOGS\n\nWebb was investigating something in the system.\nWatch his videos. Read his logs.\nFind out what he discovered.\n\nThe ambient music has changed.\nERERBUS is adjusting to your presence."
        write $txt to "C:/Users/User/Desktop/EREBUS/INBOX/PHASE2_NOTICE.txt"

        play $snd_erebus_whisper volume=0.4
        emit dialog:alert title="PHASE 2 UNLOCKED" message="New files in WEBB_FILES. New video diary available!"
        call updateStatus
    }
}

func unlockPhase3 {
