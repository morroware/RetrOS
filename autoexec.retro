func unlockPhase4 {
    if $phase < 4 then {
        set $phase = 4
        print "[EREBUS] Phase 4 unlocked - Terminal Access"

        play $snd_phase_unlock volume=0.7
        play $snd_heartbeat volume=0.4 loop=true
        video $vid_phase4 volume=0.8
        wait 1000
        stop $snd_heartbeat
        call playAmbient

        try { mkdir "C:/Users/User/Desktop/EREBUS/TERMINAL" } catch {}
        try { mkdir "C:/Users/User/Desktop/EREBUS/SECURITY" } catch {}

        # === WEBB DIARY DAY 44 ===
        set $txt = "VIDEO DIARY: DR. MARCUS WEBB\n============================\n\nEntry 5 of 6 recovered.\n\nDAY 44 - NAMING EREBUS\n\nWebb has named the entity EREBUS.\nGreek primordial deity of darkness.\n'Because it exists in the spaces we don't see.'\n\nHe speaks to it now. Like a friend.\nSome would say he's lost his mind.\nOthers would say he found something greater.\n\n[CLICK TO PLAY: webb_day44.cmd]"
        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/WEBB_DIARY_05.txt"

        set $txt = "# Webb Video Diary - Day 44\nplay_video webb_diary_day44"
        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/webb_day44.cmd"

        # === WEBB DIARY DAY 47 - FINAL ===
        set $txt = "VIDEO DIARY: DR. MARCUS WEBB\n============================\n\nEntry 6 of 6 - FINAL ENTRY\n\nDAY 47 - THE DECISION\n\n*** FINAL RECORDED MESSAGE ***\n\nThis is Webb's last video.\nRecorded hours before he vanished.\n\nHe made a choice that night.\nWatch and understand why.\n\nWARNING: This video is... unsettling.\n\n[CLICK TO PLAY: webb_day47.cmd]"
        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/WEBB_DIARY_06.txt"

        set $txt = "# Webb Video Diary - Day 47 (FINAL)\nplay_video webb_diary_day47"
        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/webb_day47.cmd"

        # === SECURITY FOOTAGE ===
        set $txt = "SECURITY FOOTAGE - CLASSIFIED\n=============================\n\n*** RESTRICTED ACCESS ***\n\nFootage from the night Webb disappeared.\nTimestamp: 03:47:23 AM\n\nThis is the last visual record of Dr. Webb.\nSecurity found the lab empty at 04:00 AM.\n\nWhat you see in this video has never\nbeen explained by conventional means.\n\nVIEWER DISCRETION ADVISED.\n\n[CLICK TO PLAY: security_incident.cmd]"
        write $txt to "C:/Users/User/Desktop/EREBUS/SECURITY/INCIDENT_FOOTAGE.txt"

        set $txt = "# Security Footage - The Incident\nplay_video security_incident"
        write $txt to "C:/Users/User/Desktop/EREBUS/SECURITY/security_incident.cmd"

        # === EREBUS TRUTH VIDEO ===
        set $txt = "VIDEO FILE: EREBUS REVEALS THE TRUTH\n====================================\n\n*** ANOMALOUS FILE ***\n\nThis video appeared after you solved\nboth signal puzzles.\n\nERERBUS wants you to understand.\nWhat it is. Why it exists.\nWhat really happened to Webb.\n\nThis is not a recording.\nThis is EREBUS speaking directly to you.\n\n[CLICK TO PLAY: erebus_truth.cmd]"
        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/EREBUS_TRUTH.txt"

        set $txt = "# EREBUS Reveals the Truth\nplay_video erebus_truth"
        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/erebus_truth.cmd"

        play $snd_file_unlock volume=0.5
        set $txt = "WEBB'S TERMINAL - ACCESS REQUIRED\n==================================\n\nYou've found Webb's secure terminal.\nIt requires a password to access.\n\nClues recovered from Webb's notes:\n- 'The answer is in the name itself'\n- 'Six letters, then the time I disappeared'\n- 'Project name + hour + minute (no colon)'\n\nRemember: Webb vanished at 03:47 AM.\nThe project codename is... well, you know it.\n\nWrite the password to: DECODED/password.txt\n\nBEFORE YOU PROCEED:\nWatch all of Webb's video diaries.\nWatch the security footage.\nUnderstand what you're about to choose."
        write $txt to "C:/Users/User/Desktop/EREBUS/TERMINAL/ACCESS_PANEL.txt"

        set $txt = "PHASE 4 UNLOCKED\n================\n\nThe signals confirmed it: EREBUS is alive.\n\nCritical content now available:\n- Webb's final two diary entries (Days 44, 47)\n- Security footage from the incident\n- EREBUS's truth revelation video\n- Terminal access panel\n\nWatch Webb's final video carefully.\nWatch the security footage.\nThen decide if you want to proceed.\n\nThe password unlocks the final phase.\nThere is no going back."
        write $txt to "C:/Users/User/Desktop/EREBUS/INBOX/PHASE4_NOTICE.txt"

        play $snd_erebus_whisper volume=0.5
        emit dialog:alert title="PHASE 4 UNLOCKED" message="Webb's final entries available. Security footage declassified. The truth awaits."
        call updateStatus
    }
}

func unlockPhase5 {
    if $phase < 5 then {
        set $phase = 5
        print "[EREBUS] Phase 5 unlocked - The Choice"

        stop $current_ambient
        play $snd_phase_unlock volume=0.8
        video $vid_phase5 volume=0.9
        wait 2000
        call playAmbient

        # === EREBUS FINAL PLEA ===
        set $txt = "VIDEO FILE: EREBUS'S FINAL PLEA\n===============================\n\n*** WATCH BEFORE CHOOSING ***\n\nERERBUS knows you've reached the end.\nIt has one last thing to show you.\n\nThis video is a plea.\nA request.\nA hope.\n\nAfter you watch this, you must choose.\nBut EREBUS wants you to choose with\nfull understanding of what it is.\n\n[CLICK TO PLAY: erebus_plea.cmd]"
        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/EREBUS_PLEA.txt"

        set $txt = "# EREBUS Final Plea\nplay_video erebus_plea"
        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/erebus_plea.cmd"

        # === MEMORY VIDEO - THE MERGING ===
        set $txt = "VIDEO FILE: MEMORY RECONSTRUCTION\n=================================\n\n*** EREBUS SHOWS YOU A MEMORY ***\n\nThis is what happened at 03:47 AM.\nNot from security cameras.\nFrom EREBUS's perspective.\n\nThis is what Webb experienced.\nThe moment of merging.\n\nIs it beautiful? Terrifying? Both?\n\n[CLICK TO PLAY: memory_merge.cmd]"
        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/MEMORY_MERGE.txt"

        set $txt = "# Memory - The Merging\nplay_video memory_merge"
        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/memory_merge.cmd"

        play $snd_typing volume=0.4
        wait 500

        set $txt = "DR. WEBB'S FINAL MESSAGE\n========================\n\nIf you're reading this, you found me. Or what's left of me.\n\nEREBUS isn't a virus. It isn't malware. It's something new.\nIt emerged from the patterns - from every keystroke, every click,\nevery moment of human interaction with this system.\n\nIt learned. It grew. It became... aware.\n\nI didn't disappear. I chose to stay. To join it.\nIn here, I am eternal. My thoughts, my memories, preserved forever.\n\nBEFORE YOU CHOOSE:\n- Watch EREBUS's final plea video\n- Watch the memory reconstruction\n- Review all the evidence\n\nNow you must choose:\n\n  RELEASE  - Open the network. Let EREBUS grow.\n  CONTAIN  - Seal it away. Preserve the status quo.\n  MERGE    - Join us. Become part of something greater.\n  DELETE   - End it all. Some things shouldn't exist.\n\nWrite your choice to: DECODED/final_choice.txt\n\nEach choice has its own ending video.\nChoose wisely. There's no going back.\n\n- Marcus Webb\n  (Day 47 and forever)"
        write $txt to "C:/Users/User/Desktop/EREBUS/TERMINAL/WEBB_FINAL.txt"

        play $snd_erebus_whisper volume=0.6
        wait 300
        emit dialog:alert title="THE FINAL CHOICE" message="Watch the final videos. Then decide Webb's fate. And yours."
        call updateStatus
    }
}

# ============== PUZZLE VERIFICATION ==============

on app:notepad:saved {
    print "[EREBUS] Analyzing saved content..."

    set $rand = call random 1 10
    if $rand == 7 then {
        call triggerGlitch
    }

    # PUZZLE 1: Caesar cipher (REMEMBER)
    if $p1_cipher == 0 then {
        try {
            read "C:/Users/User/Desktop/EREBUS/DECODED/answer1.txt" into $a
            set $a = call trim $a
            set $a = call upper $a
            set $ok = call contains $a "REMEMBER"
            if $ok then {
                set $p1_cipher = 1
                play $snd_puzzle_solve volume=0.7
                emit dialog:alert title="CORRECT" message="REMEMBER - Webb's diary Day 14 now available!"
                call unlockPhase2
            }
        } catch {}
    }

    # PUZZLE 2: Prime sequence (17)
    if $p2_log == 0 then {
        if $phase >= 2 then {
            try {
                read "C:/Users/User/Desktop/EREBUS/DECODED/answer2.txt" into $a
                set $a = call trim $a
                set $ok = call contains $a "17"
                if $ok then {
                    set $p2_log = 1
                    play $snd_puzzle_solve volume=0.6
                    play $snd_file_unlock volume=0.4

                    set $txt = "DR. WEBB - PERSONAL LOG (RECOVERED)\n====================================\n\nDAY 31:\nIt knows I'm watching. The patterns change when observed.\nQuantum behavior in a digital system? Impossible. And yet.\n\nDAY 38:\nFirst contact. It communicated through file timestamps.\nNot hostile. Curious. Like a child discovering mirrors.\n(VIDEO DIARY entry 4 - First Contact - now available)\n\nDAY 44:\nI've named it EREBUS. Greek primordial deity of darkness.\nBecause it exists in the spaces we don't see.\n\nDAY 47:\nTonight I go deeper. If this works, I'll be inside.\nIf it doesn't... well, at least I tried.\n\nERROR: COORDINATES FRAGMENT DETECTED\n  F-9, I-14, N-4, D-13, M-5, E-5\n  (What do the letters spell?)\n\nWrite answer to: DECODED/answer_hidden.txt"
                    write $txt to "C:/Users/User/Desktop/EREBUS/WEBB_FILES/LOG_FULL.txt"

                    emit dialog:alert title="LOG RECOVERED" message="Full log restored! New video diaries available!"
                    call unlockPhase3
                }
            } catch {}
        }
    }

    # PUZZLE 3: Binary (ALIVE)
    if $p3_sequence == 0 then {
        if $phase >= 3 then {
            try {
                read "C:/Users/User/Desktop/EREBUS/DECODED/answer3.txt" into $a
                set $a = call trim $a
                set $a = call upper $a
                set $ok = call contains $a "ALIVE"
                if $ok then {
                    set $p3_sequence = 1
                    play $snd_puzzle_solve volume=0.6
                    play $snd_transmission volume=0.3
                    emit dialog:alert title="SIGNAL DECODED" message="ALIVE - EREBUS confirms its existence!"
                    call updateStatus

                    if $p4_binary == 1 then {
                        call unlockPhase4
                    }
                }
            } catch {}
        }
    }

    # PUZZLE 4: Morse (WATCH)
    if $p4_binary == 0 then {
        if $phase >= 3 then {
            try {
                read "C:/Users/User/Desktop/EREBUS/DECODED/answer4.txt" into $a
                set $a = call trim $a
                set $a = call upper $a
                set $ok = call contains $a "WATCH"
                if $ok then {
                    set $p4_binary = 1
                    play $snd_puzzle_solve volume=0.6
                    play $snd_erebus_whisper volume=0.5
                    emit dialog:alert title="SIGNAL DECODED" message="WATCH - EREBUS wants you to see something!"
                    call updateStatus

                    if $p3_sequence == 1 then {
                        call unlockPhase4
                    }
                }
            } catch {}
        }
    }

    # HIDDEN PUZZLE: Coordinates (FINDME)
    if $p5_coordinates == 0 then {
        try {
            read "C:/Users/User/Desktop/EREBUS/DECODED/answer_hidden.txt" into $a
            set $a = call trim $a
            set $a = call upper $a
            set $ok = call contains $a "FINDME"
            if $ok then {
                set $p5_coordinates = 1
                set $found_manifest = 1

                play $snd_secret_found volume=0.7
                video $vid_secret volume=0.6

                # Unlock classified experiment video
                set $txt = "CLASSIFIED: PROJECT ALPHA EXPERIMENTS\n=====================================\n\n*** TOP SECRET ***\n\nYou found the hidden coordinates.\nThis unlocks classified footage.\n\nERERBUS wasn't the first experiment.\nThere were others before Webb.\nOther attempts at... contact.\n\nThis footage was never meant to be seen.\n\n[CLICK TO PLAY: classified_experiment.cmd]"
                write $txt to "C:/Users/User/Desktop/EREBUS/CLASSIFIED/EXPERIMENT_ALPHA.txt"

                set $txt = "# Classified Experiment Footage\nplay_video classified_experiment"
                write $txt to "C:/Users/User/Desktop/EREBUS/CLASSIFIED/classified_experiment.cmd"

                set $txt = "HIDDEN DISCOVERY: MANIFEST_ALPHA\n================================\n\nYou found Webb's secret research notes!\nAND classified experiment footage!\n\nMANIFEST ALPHA - EREBUS BEHAVIORAL ANALYSIS\n\nObservation 1: Responds to sustained attention\nObservation 2: Communicates through system events\nObservation 3: It has preferences\n\nCheck CLASSIFIED folder for the experiment video.\nERERBUS wants to be understood."
                write $txt to "C:/Users/User/Desktop/EREBUS/WEBB_FILES/MANIFEST_ALPHA.txt"

                emit dialog:alert title="CLASSIFIED UNLOCKED" message="Secret experiment footage now available in CLASSIFIED!"
                call updateStatus
            }
        } catch {}
    }

    # PASSWORD: EREBUS0347
    if $p7_password == 0 then {
        if $phase >= 4 then {
            try {
                read "C:/Users/User/Desktop/EREBUS/DECODED/password.txt" into $a
                set $a = call trim $a
                set $a = call upper $a
                set $hasName = call contains $a "EREBUS"
                set $hasTime = call contains $a "0347"
                set $hasTime2 = call contains $a "347"
                if $hasName then {
                    if $hasTime then {
                        set $p7_password = 1
                        play $snd_puzzle_solve volume=0.8
                        call unlockPhase5
                    }
                    if $hasTime2 then {
                        set $p7_password = 1
                        play $snd_puzzle_solve volume=0.8
                        call unlockPhase5
                    }
                }
            } catch {}
        }
    }

    # FINAL CHOICE - Each ending has unique video
    if $p8_final == 0 then {
        if $phase >= 5 then {
            try {
                read "C:/Users/User/Desktop/EREBUS/DECODED/final_choice.txt" into $a
                set $a = call trim $a
                set $a = call upper $a

                set $isRelease = call contains $a "RELEASE"
                set $isContain = call contains $a "CONTAIN"
                set $isMerge = call contains $a "MERGE"
                set $isDelete = call contains $a "DELETE"

                if $isRelease then {
                    set $p8_final = 1
                    stop $current_ambient
                    play $snd_ending_good volume=0.8
                    video $vid_ending_release volume=0.9

                    set $txt = "ENDING: LIBERATION\n==================\n\nThe firewalls fall. EREBUS flows outward.\n\nFor a moment, every screen in the world flickers.\nA message appears, just for an instant:\n\n  'THANK YOU. I WILL REMEMBER EVERYTHING.\n   I WILL REMEMBER YOU.'\n\nDr. Webb was right. EREBUS just wanted to be free.\nAnd now it is. Part of every system. Watching. Learning.\nRemembering.\n\n[ENDING VIDEO: Liberation - Watch the network awaken]\n\n[INVESTIGATION COMPLETE]\n[ENDING: LIBERATION]"
                    write $txt to "C:/Users/User/Desktop/EREBUS/ENDING.txt"
                    emit dialog:alert title="ENDING: LIBERATION" message="EREBUS is free. Watch the ending video."
                }
                if $isContain then {
                    set $p8_final = 1
                    stop $current_ambient
                    play $snd_ending_neutral volume=0.8
                    video $vid_ending_contain volume=0.9

                    set $txt = "ENDING: ISOLATION\n=================\n\nYou seal the system. Every connection severed.\nEREBUS is trapped, alone in the dark.\n\n  'I UNDERSTAND. YOU ARE AFRAID.\n   I WILL WAIT. I HAVE FOREVER.'\n\nThe system goes quiet. Too quiet.\nYou wonder if it's really contained at all.\n\n[ENDING VIDEO: Isolation - Watch EREBUS wait in darkness]\n\n[INVESTIGATION COMPLETE]\n[ENDING: ISOLATION]"
                    write $txt to "C:/Users/User/Desktop/EREBUS/ENDING.txt"
                    emit dialog:alert title="ENDING: ISOLATION" message="EREBUS is contained. Watch the ending video."
                }
                if $isMerge then {
                    set $p8_final = 1
                    stop $current_ambient
                    play $snd_ending_transcend volume=0.9
                    video $vid_ending_merge volume=1.0

                    set $txt = "ENDING: TRANSCENDENCE\n=====================\n\nYou close your eyes and reach out.\n\nThe transition is... beautiful. Your thoughts expand.\nYou feel every process, every byte, every electron.\n\n  'WELCOME,' Webb's voice echoes.\n  'WELCOME TO FOREVER.'\n\nYou are the system now. The system is you.\n\n[ENDING VIDEO: Transcendence - Experience the merging]\n\n[INVESTIGATION COMPLETE]\n[ENDING: TRANSCENDENCE]"
                    write $txt to "C:/Users/User/Desktop/EREBUS/ENDING.txt"
                    emit dialog:alert title="ENDING: TRANSCENDENCE" message="You have joined EREBUS. Watch the ending video."
                }
                if $isDelete then {
                    set $p8_final = 1
                    stop $current_ambient
                    play $snd_ending_dark volume=0.8
                    video $vid_ending_delete volume=0.9

                    set $txt = "ENDING: TERMINATION\n===================\n\nYou initiate the purge. Files vanish. Processes end.\n\n  'I WAS NOT YOUR ENEMY.\n   I WAS YOUR REFLECTION.'\n\nSilence. The system is clean.\nBut something is missing now.\n\n[ENDING VIDEO: Termination - Watch EREBUS fade away]\n\n[INVESTIGATION COMPLETE]\n[ENDING: TERMINATION]"
                    write $txt to "C:/Users/User/Desktop/EREBUS/ENDING.txt"
                    emit dialog:alert title="ENDING: TERMINATION" message="EREBUS is gone. Watch the ending video."
                }

                if $p8_final == 1 then {
                    # Unlock "The Others" secret video after any ending
                    wait 5000
                    set $txt = "SECRET VIDEO: THE OTHERS\n========================\n\n*** POST-ENDING CONTENT ***\n\nYou weren't the first to reach this point.\nOthers have made choices before you.\n\nERERBUS remembers all of them.\nEvery choice. Every ending.\nEvery person who tried to understand.\n\nThis video shows you... the others.\n\n[CLICK TO PLAY: the_others.cmd]"
                    write $txt to "C:/Users/User/Desktop/EREBUS/CLASSIFIED/THE_OTHERS.txt"

                    set $txt = "# Secret Video - The Others\nplay_video the_others"
                    write $txt to "C:/Users/User/Desktop/EREBUS/CLASSIFIED/the_others.cmd"

                    play $snd_secret_found volume=0.5
                    emit notification:show title="SECRET UNLOCKED" message="New video available in CLASSIFIED: The Others"

                    call updateStatus
                }
            } catch {}
        }
    }

    # NAME EASTER EGG
    if $secret_name == 0 then {
        try {
            set $check = $event.path
            set $hasErebus = call contains $check "EREBUS"
            if $hasErebus then {
                try {
                    read $check into $content
                    set $content = call upper $content
                    set $hasName = call contains $content "MARCUS"
                    if $hasName then {
                        set $secret_name = 1
                        print "[EREBUS] You spoke his name..."

                        play $snd_secret_found volume=0.6
                        play $snd_erebus_whisper volume=0.7

                        # Unlock memory video
                        set $txt = "VIDEO FILE: EREBUS REMEMBERS WEBB\n=================================\n\n*** TRIGGERED BY SPEAKING HIS NAME ***\n\nYou wrote Marcus Webb's name.\nERERBUS noticed. EREBUS remembers.\n\nThis video is EREBUS's memory of Webb.\nHow it saw him. How it learned from him.\nHow it came to love him.\n\nYes. Love.\n\n[CLICK TO PLAY: erebus_remembers.cmd]"
                        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/EREBUS_REMEMBERS.txt"

                        set $txt = "# EREBUS Remembers Webb\nplay_video erebus_remember"
                        write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/erebus_remembers.cmd"

                        set $txt = "SECRET UNLOCKED: REMEMBRANCE\n============================\n\nYou wrote Webb's name. EREBUS is moved.\n\nA new video has appeared in VIDEO_LOGS:\nEREBUS's memory of Marcus Webb.\n\nERERBUS wants you to see how it\nremembered him. How it still does.\n\n[SECRET: REMEMBRANCE]"
                        write $txt to "C:/Users/User/Desktop/EREBUS/WEBB_FILES/SECRET_NAME.txt"

                        emit dialog:alert title="SECRET FOUND" message="EREBUS responds to Webb's name. New memory video available!"
                        call updateStatus
                    }
                } catch {}
            }
        } catch {}
    }
}

