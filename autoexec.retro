# ============== IDLE DETECTION ==============

on system:idle {
    set $idle_time = $idle_time + 1

    if $idle_time == 30 then {
        play $snd_erebus_whisper volume=0.2
        emit notification:show title="EREBUS" message="Still there? I'm still here. Always."
    }

    if $idle_time == 60 then {
        if $secret_patience == 0 then {
            set $secret_patience = 1
            print "[EREBUS] Your patience has been noted..."

            play $snd_secret_found volume=0.6
            video $vid_secret volume=0.5

            # Unlock training video
            set $txt = "VIDEO FILE: SYSTEM TRAINING\n===========================\n\n*** UNLOCKED BY PATIENCE ***\n\nYour patience impressed EREBUS.\nIt wants to show you something few have seen.\n\nOriginal training video for EREBUS operators.\nNotice the warnings they gave.\nNotice how they were ignored.\n\n[CLICK TO PLAY: system_training.cmd]"
            write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/TRAINING.txt"

            set $txt = "# System Training Video\nplay_video system_training"
            write $txt to "C:/Users/User/Desktop/EREBUS/VIDEO_LOGS/system_training.cmd"

            set $txt = "SECRET UNLOCKED: PATIENCE\n=========================\n\nYou waited. EREBUS noticed.\n\nNew video unlocked: System Training footage!\nSee the warnings they ignored.\n\n[SECRET: THE GIFT OF ATTENTION]"
            write $txt to "C:/Users/User/Desktop/EREBUS/WEBB_FILES/SECRET_PATIENCE.txt"

            emit dialog:alert title="SECRET FOUND" message="Patience rewarded! Training video unlocked!"
            call updateStatus
        }
    }
}

# ============== WINDOW FOCUS TRACKING ==============

on window:focus {
    set $files_explored = $files_explored + 1

    set $rand = call random 1 20
    if $rand == 13 then {
        call triggerGlitch
    }

    if $files_explored == 20 then {
        if $found_memory == 0 then {
            set $found_memory = 1
            print "[EREBUS] Thorough exploration detected. Bonus content unlocked."

            play $snd_secret_found volume=0.6
            video $vid_secret volume=0.6

            # Unlock memory of Webb's discovery
            set $txt = "VIDEO FILE: MEMORY - WEBB'S DISCOVERY\n=====================================\n\n*** UNLOCKED BY EXPLORATION ***\n\nYou've explored everything.\nERERBUS wants to share a special memory.\n\nThis is the moment Webb first realized\nwhat EREBUS truly was.\n\nThe moment of discovery. Of wonder.\nOf the beginning of understanding.\n\n[CLICK TO PLAY: memory_discovery.cmd]"
