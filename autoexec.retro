on app:calculator:opened {
    if $opened_calc == 0 then {
        set $opened_calc = 1
        wait 1500
        print "[EREBUS] Calculator opened. EREBUS appreciates logic..."
        play $snd_alert volume=0.3
        emit notification:show title="EREBUS" message="Numbers have meaning. Try 347..."
    }
}

on app:calculator:result {
    set $r = $event.result
    if $r == 347 then {
        if $secret_347 == 0 then {
            set $secret_347 = 1
            print "[EREBUS] The sacred number! Unlocking secret..."

            play $snd_secret_found volume=0.7
            play $snd_heartbeat volume=0.5
            video $vid_secret volume=0.6
            wait 2000
            stop $snd_heartbeat

            set $txt = "SECRET UNLOCKED: 03:47\n======================\n\nYou entered the time of Webb's disappearance.\n\n03:47 AM - THE CONVERGENCE\n\nThis number unlocks additional security footage.\nCheck the SECURITY folder for new content.\n\n[SECRET: THE CONVERGENCE TIME]"
            write $txt to "C:/Users/User/Desktop/EREBUS/WEBB_FILES/SECRET_347.txt"

            # Unlock lobby security footage
            try { mkdir "C:/Users/User/Desktop/EREBUS/SECURITY" } catch {}
            set $txt = "SECURITY FOOTAGE - LOBBY CAM\n============================\n\nFootage from the building lobby.\nThe night of the incident.\n\nWatch Webb enter the building.\nNote the time. Note his expression.\nHe knew what he was about to do.\n\n[CLICK TO PLAY: security_lobby.cmd]"
            write $txt to "C:/Users/User/Desktop/EREBUS/SECURITY/LOBBY_CAM.txt"

            set $txt = "# Security Footage - Lobby\nplay_video security_lobby"
            write $txt to "C:/Users/User/Desktop/EREBUS/SECURITY/security_lobby.cmd"

            emit dialog:alert title="SECRET FOUND" message="03:47 recognized! Security footage unlocked!"
            call updateStatus
        }
    }
    if $r == 42 then {
        play $snd_glitch volume=0.3
        emit notification:show title="EREBUS" message="The answer to everything? Close, but not quite..."
    }
}

on app:terminal:opened {
