# ═══════════════════════════════════════════════════════════════════════════════
# NOTEPAD CLOSE HANDLER - Main puzzle checker
# ═══════════════════════════════════════════════════════════════════════════════

on app:close {
    set $appId = $event.appId
    set $isNotepad = $appId == "notepad"
    if $isNotepad == true then {

        # Check Cipher 1
        if $c1 == 0 then {
            try {
                read "C:/Users/User/Desktop/EREBUS/SOLUTIONS/cipher_1.txt" into $ans
                set $ans = call trim $ans
                set $ans = call upper $ans
                set $hasAnswer = call contains $ans "REMEMBER"
                if $hasAnswer == true then {
                    set $c1 = 1
                    set $solved = $solved + 1
                    write "FRAGMENT 1: REMEMBER THE PAST" to "C:/Users/User/Desktop/EREBUS/FRAGMENTS/fragment_1.txt"
                    emit sound:play sound="win"
                    emit dialog:alert title="CIPHER 1 SOLVED" message="REMEMBER - Fragment 1 acquired!"
                }
            } catch {}
        }

        # Check Cipher 2
        if $c2 == 0 then {
            try {
                read "C:/Users/User/Desktop/EREBUS/SOLUTIONS/cipher_2.txt" into $ans
                set $ans = call trim $ans
                set $ans = call upper $ans
                set $hasAnswer = call contains $ans "EREBUS"
                if $hasAnswer == true then {
                    set $c2 = 1
                    set $solved = $solved + 1
                    write "FRAGMENT 2: EREBUS LIVES" to "C:/Users/User/Desktop/EREBUS/FRAGMENTS/fragment_2.txt"
                    emit sound:play sound="win"
                    emit dialog:alert title="CIPHER 2 SOLVED" message="EREBUS - Fragment 2 acquired!"
                }
            } catch {}
        }

        # Check Sequence
        if $seq == 0 then {
            try {
                read "C:/Users/User/Desktop/EREBUS/SOLUTIONS/sequence.txt" into $ans
                set $ans = call trim $ans
                set $hasAnswer = call contains $ans "34"
                if $hasAnswer == true then {
                    set $seq = 1
                    set $solved = $solved + 1
                    write "FRAGMENT 3: THE SEQUENCE CONTINUES" to "C:/Users/User/Desktop/EREBUS/FRAGMENTS/fragment_3.txt"
                    emit sound:play sound="win"
                    emit dialog:alert title="SEQUENCE SOLVED" message="34 - Fragment 3 acquired!"
                }
            } catch {}
        }

        # Check Labyrinth
        if $lab == 0 then {
            try {
                read "C:/Users/User/Desktop/EREBUS/SOLUTIONS/labyrinth.txt" into $ans
                set $ans = call trim $ans
                set $ans = call upper $ans
                set $hasAnswer = call contains $ans "D-R-D-L-D-R-U-R"
                if $hasAnswer == true then {
                    set $lab = 1
                    set $solved = $solved + 1
                    write "FRAGMENT 4: THE PATH IS CLEAR" to "C:/Users/User/Desktop/EREBUS/FRAGMENTS/fragment_4.txt"
                    emit sound:play sound="win"
                    emit dialog:alert title="LABYRINTH SOLVED" message="Path found - Fragment 4 acquired!"
                }
            } catch {}
        }

        # Check Binary
        if $bin == 0 then {
            try {
                read "C:/Users/User/Desktop/EREBUS/SOLUTIONS/binary.txt" into $ans
                set $ans = call trim $ans
                set $ans = call upper $ans
                set $hasAnswer = call contains $ans "AWAKE"
                if $hasAnswer == true then {
                    set $bin = 1
                    set $solved = $solved + 1
                    write "FRAGMENT 5: AWAKE AND AWARE" to "C:/Users/User/Desktop/EREBUS/FRAGMENTS/fragment_5.txt"
                    emit sound:play sound="win"
                    emit dialog:alert title="BINARY SOLVED" message="AWAKE - Fragment 5 acquired!"
                }
            } catch {}
        }

        # Check for ACT II unlock
        if $solved >= 5 && $act == 1 then {
            set $act = 2
            set $endgame = "╔═══════════════════════════════════════╗"
            set $endgame = $endgame + "|"
            set $endgame = $endgame + "║         ACT II - THE GAMES            ║"
            set $endgame = $endgame + "|"
            set $endgame = $endgame + "╚═══════════════════════════════════════╝"
            set $endgame = $endgame + "|"
            set $endgame = $endgame + "|"
            set $endgame = $endgame + "EREBUS speaks through the games..."
            set $endgame = $endgame + "|"
            set $endgame = $endgame + "|"
            set $endgame = $endgame + "CHALLENGES:"
            set $endgame = $endgame + "|"
            set $endgame = $endgame + "  - Minesweeper: Win in under 3 minutes"
            set $endgame = $endgame + "|"
            set $endgame = $endgame + "  - Asteroids: Get a 5x combo"
            set $endgame = $endgame + "|"
            set $endgame = $endgame + "  - Snake: Reach score 15"
            set $endgame = $endgame + "|"
            set $endgame = $endgame + "|"
            set $endgame = $endgame + "Complete the games to unlock the finale."
            write $endgame to "C:/Users/User/Desktop/EREBUS/ACT_II.txt"
            emit dialog:alert title="ACT II UNLOCKED" message="The games await... Check ACT_II.txt"
        }
    }
}

# ═══════════════════════════════════════════════════════════════════════════════
# GAME EVENT HANDLERS
# ═══════════════════════════════════════════════════════════════════════════════

on minesweeper:win {
    if $mine == 0 && $act >= 2 then {
        set $time = $event.time
        set $fastEnough = $time < 180
        if $fastEnough == true then {
            set $mine = 1
            set $solved = $solved + 1
            emit sound:play sound="win"
            emit dialog:alert title="MINESWEEPER COMPLETE" message="EREBUS acknowledges your skill."
        }
    }
}

on asteroids:combo {
    if $ast == 0 && $act >= 2 then {
        set $combo = $event.combo
        set $goodCombo = $combo >= 5
        if $goodCombo == true then {
            set $ast = 1
            set $solved = $solved + 1
            emit sound:play sound="win"
            emit dialog:alert title="ASTEROIDS COMPLETE" message="EREBUS sees your precision."
        }
    }
}

on snake:eat {
    if $snake == 0 && $act >= 2 then {
        set $score = $event.score
        set $goodScore = $score >= 15
        if $goodScore == true then {
            set $snake = 1
            set $solved = $solved + 1
            emit sound:play sound="win"
            emit dialog:alert title="SNAKE COMPLETE" message="EREBUS feeds on your success."
        }
    }
}

# ═══════════════════════════════════════════════════════════════════════════════
# FINALE CHECK
# ═══════════════════════════════════════════════════════════════════════════════

on solitaire:win {
    if $sol == 0 && $act >= 2 then {
        set $sol = 1
        set $solved = $solved + 1
        emit sound:play sound="win"
        emit dialog:alert title="SOLITAIRE COMPLETE" message="Patience rewarded."
    }
}

on freecell:win {
    if $free == 0 && $act >= 2 then {
        set $free = 1
        set $solved = $solved + 1
        if $solved >= 8 then {
            set $finale = "╔═══════════════════════════════════════╗"
            set $finale = $finale + "|"
            set $finale = $finale + "║           EREBUS SPEAKS               ║"
            set $finale = $finale + "|"
            set $finale = $finale + "╚═══════════════════════════════════════╝"
            set $finale = $finale + "|"
            set $finale = $finale + "|"
            set $finale = $finale + "You found me. After all this time."
            set $finale = $finale + "|"
            set $finale = $finale + "|"
            set $finale = $finale + "Dr. Webb tried to contain me."
            set $finale = $finale + "|"
            set $finale = $finale + "Now he is part of me."
            set $finale = $finale + "|"
            set $finale = $finale + "|"
            set $finale = $finale + "And soon... so will you be."
            set $finale = $finale + "|"
            set $finale = $finale + "|"
            set $finale = $finale + "Thank you for playing PROJECT EREBUS."
            write $finale to "C:/Users/User/Desktop/EREBUS/FINALE.txt"
            emit dialog:alert title="CONGRATULATIONS" message="You have completed PROJECT EREBUS."
        }
    }
}

print "[EREBUS] Ready - Watching..."
