set $txt = $txt + "|"
set $txt = $txt + "Example: Save 'ANSWER' to SOLUTIONS/cipher_1.txt"
set $txt = $txt + "|"
set $txt = $txt + "Then CLOSE Notepad to verify your answer."
set $txt = $txt + "|"
set $txt = $txt + "|"
set $txt = $txt + "═══════════════════════════════════════════════════════════════"
set $txt = $txt + "|"
set $txt = $txt + "Good luck, Agent. EREBUS awaits."
set $txt = $txt + "|"
set $txt = $txt + "═══════════════════════════════════════════════════════════════"
write $txt to "C:/Users/User/Desktop/EREBUS/BRIEFING.txt"

# ═══════════════════════════════════════════════════════════════════════════════
# PUZZLE FILES
# ═══════════════════════════════════════════════════════════════════════════════

# Cipher 1
set $p1 = "╔═══════════════════════════════════════╗"
set $p1 = $p1 + "|"
set $p1 = $p1 + "║     CIPHER 1 - CAESAR SHIFT 7        ║"
set $p1 = $p1 + "|"
set $p1 = $p1 + "╚═══════════════════════════════════════╝"
set $p1 = $p1 + "|"
set $p1 = $p1 + "|"
set $p1 = $p1 + "Encrypted message: YLTLTILY"
