write $p3 to "C:/Users/User/Desktop/EREBUS/PUZZULAR/SEQUENCE.txt"

# Labyrinth
set $p4 = "╔═══════════════════════════════════════╗"
set $p4 = $p4 + "|"
set $p4 = $p4 + "║      LABYRINTH - PATH PUZZLE         ║"
set $p4 = $p4 + "|"
set $p4 = $p4 + "╚═══════════════════════════════════════╝"
set $p4 = $p4 + "|"
set $p4 = $p4 + "|"
