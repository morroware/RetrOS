set $p2 = $p2 + "|"
set $p2 = $p2 + "|"
set $p2 = $p2 + "Step 1: Shift each letter BACK by 4"
set $p2 = $p2 + "|"
set $p2 = $p2 + "Step 2: Reverse the entire result"
set $p2 = $p2 + "|"
set $p2 = $p2 + "|"
set $p2 = $p2 + "Save answer to: SOLUTIONS/cipher_2.txt"
write $p2 to "C:/Users/User/Desktop/EREBUS/PUZZULAR/CIPHER_2.txt"

# Sequence
set $p3 = "╔═══════════════════════════════════════╗"
set $p3 = $p3 + "|"
set $p3 = $p3 + "║      SEQUENCE - FIBONACCI            ║"
set $p3 = $p3 + "|"
set $p3 = $p3 + "╚═══════════════════════════════════════╝"
set $p3 = $p3 + "|"
set $p3 = $p3 + "|"
set $p3 = $p3 + "1, 1, 2, 3, 5, 8, 13, 21, ?"
